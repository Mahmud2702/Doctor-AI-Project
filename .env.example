# ═══════════════════════════════════════════════════════════════════════
# ClinicAssist AI — .env.example
# Copy this file to `.env` and fill in your actual API keys.
# NEVER commit your real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────────────────────────
# Required. Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── LangSmith Tracing ────────────────────────────────────────────────────
# Required for tracing. Sign up free at: https://smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=ClinicAssist-AI          # Project name in LangSmith dashboard
# LANGCHAIN_TRACING_V2 and LANGCHAIN_ENDPOINT are set in backend.py automatically.

# ── Tavily Search ────────────────────────────────────────────────────────
# Required for the Search Agent. Free tier at: https://app.tavily.com
TAVILY_API_KEY=tvly-...
